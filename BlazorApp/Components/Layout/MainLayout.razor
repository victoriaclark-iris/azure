@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row phantom-top px-4">
            <div class="top-brand">
                <div class="top-brand-title">Phantom Thief Network</div>
                <div class="top-brand-subtitle">Steal Back Your Schedule</div>
            </div>
            <a class="about-link" href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
